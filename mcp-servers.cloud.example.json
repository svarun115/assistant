{
  "_comment": "Cloud + stdio MCP server config for ~/.claude.json → mcpServers section.",
  "_usage": "Replace YOUR-DOMAIN and paste into the 'mcpServers' key in ~/.claude.json.",
  "_auth": "Remote servers use OAuth 2.1. Claude Code handles auth automatically via /mcp command.",
  "_local_equivalent": "http://127.0.0.1:9001-9005/mcp via MCP Server Manager",

  "workiq": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@microsoft/workiq",
      "mcp"
    ]
  },
  "ado": {
    "type": "stdio",
    "command": "bash",
    "args": [
      "C:/Users/YOUR_USERNAME/.claude/scripts/ado-mcp.sh",
      "Office"
    ]
  },

  "github": {
    "type": "sse",
    "url": "https://YOUR-DOMAIN/github/sse"
  },
  "personal-journal": {
    "type": "http",
    "url": "https://YOUR-DOMAIN/journal-db/mcp"
  },
  "garmin": {
    "type": "http",
    "url": "https://YOUR-DOMAIN/garmin/mcp"
  },
  "google-workspace": {
    "type": "http",
    "url": "https://YOUR-DOMAIN/google/mcp"
  },
  "google-places": {
    "type": "http",
    "url": "https://YOUR-DOMAIN/places/mcp"
  },
  "splitwise": {
    "type": "http",
    "url": "https://YOUR-DOMAIN/splitwise/mcp"
  }
}

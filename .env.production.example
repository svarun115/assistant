# Personal Assistant — MCP Servers Production Environment
# Copy to .env.production and fill in all values.
# NEVER commit .env.production (it is gitignored).
#
# Usage: docker compose --env-file .env.production up -d

# ─── GitHub tokens ───────────────────────────────────────────────────────────
# Provisioning: used to clone private repos (svarun115/assistant, svarun115/claude-config)
# MCP server:   used by the GitHub MCP container (same PAT, different env var name)
# Create at: github.com/settings/tokens
GITHUB_TOKEN=your-github-pat
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat

# ─── OAuth Auth Gateway ────────────────────────────────────────────────────
# Domain where servers are hosted (no protocol, no trailing slash)
AUTH_DOMAIN=your-domain.com
# Only this Google account can authenticate
AUTH_OWNER_EMAIL=your@gmail.com
# JWT signing secret — generate: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=your-jwt-signing-secret
# Google OAuth 2.0 Web Client (type: "Web application" in Google Cloud Console)
# Redirect URI: https://<AUTH_DOMAIN>/auth/callback
AUTH_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# PostgreSQL (assistant_system database)
SYSTEM_DB_URL=postgresql://pgadmin:YOUR-DB-PASSWORD@YOUR-SERVER.postgres.database.azure.com:5432/assistant_system

# ─── Journal DB MCP (db-mcp-server) ─────────────────────────────────────────
DB_HOST=YOUR-SERVER.postgres.database.azure.com
DB_PORT=5432
DB_NAME=varun_journal
DB_USER=pgadmin
DB_PASSWORD=YOUR-DB-PASSWORD
DB_SSL_MODE=require
QUERY_MODE=structured
MEMORY_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Garmin MCP ──────────────────────────────────────────────────────────────
# Used on first run only to authenticate and populate the garmin-tokens volume.
# Remove after first successful auth — garth refreshes tokens automatically.
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password

# ─── Google Places MCP ───────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ─── Splitwise MCP ───────────────────────────────────────────────────────────
# Generate at: https://secure.splitwise.com/apps → your app → Access Token
SPLITWISE_ACCESS_TOKEN=your-splitwise-access-token
